/* Vanilla brand pack — <Client Name>
   Brand brief: <primary theme: dark|light> · <one-line character>
   Generated by vanilla-brand. Overrides --vanilla-* tokens; anything not
   listed falls through to tokens.css (the default skin).
   Load LAST: @import "tokens.css"; [theme.css if Tailwind;] @import "brand.css";
   AA is checked by vanilla-audit (contrast.mjs --brand): it flags any failing pair and
   prints a hue-preserving suggested value to apply here. */
:root {
  /* Accent — the brand color (hover/focus derived) */
  --vanilla-primary: #2f6df0;
  --vanilla-primary-hover: #5688f5;
  --vanilla-primary-focus: #2f6df0;

  /* Neutrals — canvas + surface ladder + hairlines (light re-skin overrides few; full identity overrides all) */
  --vanilla-canvas: #07090d;
  --vanilla-surface-1: #11141a;

  /* Type — keep Inter (omit to inherit) or swap the family */
  /* --vanilla-font-sans: "Geist", -apple-system, system-ui, sans-serif; */

  /* Radii / density — override the scale or a single character if the brand needs it */
  /* --vanilla-radius-md: 4px; */
}

/* The opposite theme — derived (hue preserved, surface/ink relationship inverted).
   vanilla-audit validates AA over BOTH blocks and suggests a value for any failing pair. */
:root[data-theme="light"] {
  --vanilla-primary: #2257c8;
  --vanilla-primary-hover: #3568d8;
  --vanilla-primary-focus: #2257c8;
  --vanilla-canvas: #f3f5f9;
  --vanilla-surface-1: #ffffff;
}
